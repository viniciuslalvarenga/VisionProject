<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <org.opencv.android.JavaCameraView
        android:id="@+id/camera_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:show_fps="true"
        app:camera_id="back" />

    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#A0000000"
        android:padding="8dp"
        android:text="00:00"
        android:textColor="#FF0000"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/debug_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#A0000000"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_debug_pcc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PCC: 0.0000"
            android:textColor="#00FF00"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_debug_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: IDLE"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_debug_discard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descarte: 0%"
            android:textColor="#FFFF00"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_debug_ita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ITA: 0 pts"
            android:textColor="#00FFFF"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#80000000"
        app:layout_constraintBottom_toTopOf="@id/button_container">

        <TextView
            android:id="@+id/tv_theta_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PCC Threshold (θ): 0.85"
            android:textColor="#FFFF00"
            android:textSize="10sp" />
        <SeekBar
            android:id="@+id/sb_theta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="85" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_threshold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Canny Threshold: 50"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
            <Switch
                android:id="@+id/sw_canny"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CANNY"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                tools:ignore="UseSwitchCompatPort" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/sb_threshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="255"
            android:progress="50" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset"
            android:textSize="10sp" />

        <ToggleButton
            android:id="@+id/btn_record"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textOn="CAM OFF"
            android:textOff="CAM ON"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btn_capture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOTO"
            android:textSize="10sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
