<?xml version="1.0" encoding="utf-8"?>
<!--
  Cor de fundo dos botoes da Activity de Calibracao.
  Roxo Material padrao quando habilitado, cinza quando desabilitado.
  Garante que botoes desabilitados sejam *visiveis* (mesmo que nao clicaveis).
-->
